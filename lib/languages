class SugubaApp extends StatelessWidget {
  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      title: 'SUGUBA MALI',
      locale: Locale('fr'), // سيتغير بحسب اختيار المستخدم
      supportedLocales: [Locale('ar'), Locale('fr'), Locale('en')],
      localizationsDelegates: [
        AppLocalizations.delegate, // ستحتاج لكتابة delegate كامل
        GlobalMaterialLocalizations.delegate,
        GlobalWidgetsLocalizations.delegate,
      ],
      home: MainScreen(),
    );
  }
}

